# Copy to `.env` and fill in production-safe values.

# Risk-based speaker similarity thresholds (0–1). Tune per deployment.
THRESH_LOW=0.5
THRESH_MED=0.6
THRESH_HIGH=0.7

# Legacy single threshold (optional; backend may still reference)
THRESHOLD=0.62

# Secrets — use long random strings in production
AES_KEY=change_me_generate_a_secure_random_string
HMAC_SECRET=change_me
JWT_SECRET=change_me
KMS_KEY=change_me

# Whisper model: tiny, base, small, medium, large (larger = slower, more accurate)
ASR_MODEL_SIZE=tiny

# Verbose errors and traces when true
DEV_MODE=true

# Liveness (spectral flatness) gate
LIVENESS_THRESH=0.5
